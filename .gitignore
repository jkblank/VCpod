.venv/
__pycache__/
*.pyc
.pytest_cache/

.env

# Real per-user profiles contain personal playlist IDs and device info —
# only the example profiles (alice.yaml, bob.yaml) are meant to be
# committed as templates.
config/profiles/john.yaml

config/secrets/**
!config/secrets/.gitkeep

# Fake demonstration credentials pairing with config/profiles/alice.yaml
# — not real, safe to commit. Everything else under config/secrets/
# stays ignored.
!config/secrets/pocketcasts/
!config/secrets/pocketcasts/alice.json

state/**
!state/.gitkeep

library/**
!library/.gitkeep

# Real device backup snapshots (default: state/device_backups/, already
# covered by state/** above) can be tens to hundreds of GB — never meant
# to be committed. Catches a --backup-dir override too, if placed here.
services/sync-orchestrator/_backups/

# bgutil-ytdlp-pot-provider — third-party companion service (own git repo,
# cloned not vendored) that supplies YouTube PO Tokens to yt-dlp. See
# notes.md. Not our code, never meant to be committed.
services/fetcher-ytmusic/pot-provider/
