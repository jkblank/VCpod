# Copy to .env and fill in per-deployment.
# Currently unused by the services themselves — no service reads any env
# vars yet. Real variables land here as each service needs them.

# Which music-source fetcher containers to build/run — Docker Compose's
# own profile mechanism (docker-compose.yml), one profile per source,
# matching config/global.yaml's sources.*.enabled flags. Compose doesn't
# read global.yaml itself, so keep these two in sync by hand. Only
# list the sources this household actually uses — e.g. an
# Apple-Music-only household should just have "apple" here, not all
# three. library-manager/podcast-manager always run regardless, no
# profile needed for those.
#
# COMPOSE_PROFILES=apple
# COMPOSE_PROFILES=apple,spotify,ytmusic
